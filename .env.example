# IMPERIUM server environment (deploy/OPERATIONS.md §2).
# Copy to .env and adjust; every variable has an in-code default, so a bare
# `node dist/index.js` boots without any of these set.

# TCP port the HTTP + Socket.IO server listens on (bound to 0.0.0.0).
PORT=8080

# Comma-separated list of allowed browser origins for BOTH the Express CORS
# middleware and the socket.io CORS config. When unset: cross-origin denied
# in production (NODE_ENV=production); http://localhost:5173 (Vite dev
# client) otherwise.
CORS_ORIGIN=http://localhost:5173

# Seconds an empty room (0 connected players) survives before the reaper
# deletes it.
ROOM_TTL_SECONDS=3600

# Minimum log level emitted as single-line JSON to stdout:
# debug | info | warn | error.
LOG_LEVEL=info
