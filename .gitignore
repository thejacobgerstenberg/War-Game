# Root .gitignore

node_modules/
dist/
build/
.DS_Store
*.log
.env
.env.local
coverage/
.vscode/
.idea/

# --- Vite / build outputs ---
.vite/
*.local
client/dist/
dist-ssr/

# --- Node / npm extras ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/

# --- Test / coverage ---
.nyc_output/
*.lcov

# --- Env variants ---
.env.*.local
.env.development.local
.env.production.local
# Keep the committed template tracked
!.env.example

# --- Editor / OS junk ---
Thumbs.db
*.swp
*~
.cache/

# --- Sim / generated asset output ---
sim/out/
sim/results/
*.tmp

# --- TypeScript build info ---
*.tsbuildinfo
